{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markforge",
  "version": "0.1.0",
  "identifier": "dev.markforge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markforge",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": {
      "../templates/default/reference.docx": "templates/default/reference.docx",
      "../templates/default/pdf-template.typ": "templates/default/pdf-template.typ"
    },
    "externalBin": ["binaries/pandoc", "binaries/typst"],
    "shortDescription": "Editor visual para Markdown com exportação DOCX/PDF",
    "longDescription": "Markforge é um editor WYSIWYG para arquivos Markdown (.md) que preserva o texto puro como fonte da verdade e permite exportar documentos DOCX e PDF prontos, com capa, cabeçalho e rodapé configuráveis por template. Pandoc e Typst vêm embutidos no aplicativo — nenhuma instalação adicional é necessária.",
    "category": "Productivity",
    "publisher": "Walter Maier Neto",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
