{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões padrão da janela principal do Markforge",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/pandoc", "sidecar": true },
        { "name": "binaries/typst", "sidecar": true }
      ]
    }
  ]
}
